{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "agents/**/*.ts",
    "workflows/**/*.ts",
    "skills/**/*.md",
    "cloudflare.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
