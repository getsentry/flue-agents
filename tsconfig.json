{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": [
    "evals/**/*.ts",
    "src/**/*.ts",
    "src/**/*.md",
    "vitest.evals.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
