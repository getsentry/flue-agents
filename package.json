{
  "name": "flue-agents",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false flue dev --target cloudflare --env .env.local",
    "build": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false flue build --target cloudflare --env /dev/null",
    "build:cloudflare": "pnpm run test && pnpm run typecheck && pnpm run build",
    "deploy": "pnpm run build && pnpm run deploy:cloudflare",
    "deploy:cloudflare": "CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false wrangler deploy",
    "evals": "vitest run --config vitest.evals.config.ts",
    "test": "node --test --experimental-strip-types --experimental-test-module-mocks tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.12.1",
    "@flue/github": "1.0.0-beta.1",
    "@flue/runtime": "^0.11.1",
    "@sentry/cloudflare": "^10.58.0",
    "agents": "^0.14.1",
    "hono": "4.12.25",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "@flue/cli": "^0.11.1",
    "dotenv": "17.4.2",
    "typescript": "^6.0.3",
    "vitest": "4.1.7",
    "vitest-evals": "0.14.0",
    "wrangler": "^4.100.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "@mongodb-js/zstd",
      "core-js-pure",
      "esbuild",
      "node-liblzma",
      "protobufjs",
      "sharp",
      "workerd"
    ]
  }
}
