{
  "name": "flue-agents",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": ">=22.18.0"
  },
  "scripts": {
    "dev": "flue dev --target cloudflare",
    "build": "flue build --target cloudflare",
    "deploy": "pnpm run build && wrangler deploy",
    "test": "node --test --experimental-strip-types --experimental-test-module-mocks tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.12.1",
    "@flue/runtime": "^0.11.1",
    "@sentry/cloudflare": "^10.58.0",
    "agents": "^0.14.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260615.1",
    "@flue/cli": "^0.11.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "@mongodb-js/zstd",
      "core-js-pure",
      "esbuild",
      "node-liblzma",
      "protobufjs",
      "sharp",
      "workerd"
    ]
  }
}
