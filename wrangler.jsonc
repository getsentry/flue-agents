{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "sentry-flue-agents",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueIssueTriageAgent",
        "FlueIssueTriageWorkflow",
        "Sandbox"
      ]
    }
  ],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile"
    }
  ]
}
