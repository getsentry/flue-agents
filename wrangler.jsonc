{
  "$schema": "https://workers.cloudflare.com/schema/wrangler.json",
  "name": "sentry-flue-agents",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "logs": {
      "enabled": true,
      "destinations": ["sentry-pierre-logs"]
    }
  },
  "ai": {
    "binding": "AI"
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "GitHubWebhookDeliveryClaims",
        "name": "GITHUB_WEBHOOK_DELIVERY_CLAIMS"
      },
      {
        "class_name": "Sandbox",
        "name": "Sandbox"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueIssueTriageAgent",
        "FlueIssueTriageWorkflow",
        "Sandbox"
      ]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["GitHubWebhookDeliveryClaims"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["FlueIssueTriageEvalWorkflow"]
    }
  ],
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile"
    }
  ]
}
